# Claude CLI bug scanner for filigree.
#
# To activate:
#   filigree scanner enable claude
#
# Requires: `claude` CLI on PATH
# Uses the packaged filigree-scanner-claude entrypoint

[scanner]
name = "claude"
description = "Per-file bug hunt using Claude CLI"
command = "filigree-scanner-claude"
args = ["--root", "{project_root}", "--file", "{file}", "--max-files", "1", "--api-url", "{api_url}", "--scan-run-id", "{scan_run_id}", "--prompt", "{prompt}"]
file_types = ["py"]
