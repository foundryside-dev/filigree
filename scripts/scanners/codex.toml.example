# Codex bug scanner for filigree.
#
# To activate:
#   filigree scanner enable codex
#
# Requires: `codex` CLI on PATH
# Uses the packaged filigree-scanner-codex entrypoint

[scanner]
name = "codex"
description = "Per-file bug hunt using Codex CLI"
command = "filigree-scanner-codex"
args = ["--root", "{project_root}", "--file", "{file}", "--max-files", "1", "--api-url", "{api_url}", "--scan-run-id", "{scan_run_id}", "--prompt", "{prompt}"]
file_types = ["py"]
